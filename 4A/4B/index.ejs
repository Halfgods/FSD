<!DOCTYPE html>
<html>
<head>
    <title>API Dashboard</title>
    <style>
        body {
            font-family: Arial;
            background: #f4f4f4;
            padding: 20px;
        }

        .container {
            max-width: 800px;
            margin: auto;
        }

        .box {
            background: #ddd;
            padding: 15px;
            margin-bottom: 20px;
            white-space: pre-wrap;
        }

        input {
            width: 100%;
            padding: 10px;
            margin-bottom: 10px;
        }

        .buttons button {
            padding: 10px 15px;
            border: none;
            color: white;
            margin-right: 5px;
            cursor: pointer;
        }

        .get { background: #2ecc71; }
        .post { background: #3498db; }
        .put { background: #9b59b6; }
        .patch { background: #f1c40f; }
        .delete { background: #e74c3c; }
    </style>
</head>
<body>

<div class="container">

    <!-- RESPONSE DISPLAY -->
    <% if (response) { %>
        <div class="box">
            <%= JSON.stringify(response, null, 2) %>
        </div>
    <% } %>

    <!-- FORM -->
    <form action="/data" method="POST">

        <label>Roll Number:</label>
        <input type="number" name="roll" required>

        <label>Route:</label>

        <div class="buttons">
            <button class="get" name="method" value="GET">GET</button>
            <button class="post" name="method" value="POST">POST</button>
            <button class="put" name="method" value="PUT">PUT</button>
            <button class="patch" name="method" value="PATCH">PATCH</button>
            <button class="delete" name="method" value="DELETE">DELETE</button>
        </div>

    </form>

</div>

</body>
</html>